{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.agentkitai/lore",
  "description": "Cross-agent memory over MCP: hybrid recall, knowledge graph, private/shared visibility, redaction.",
  "title": "Lore",
  "websiteUrl": "https://github.com/agentkitai/lore",
  "repository": {
    "url": "https://github.com/agentkitai/lore",
    "source": "github"
  },
  "version": "1.3.0",
  "packages": [
    {
      "registryType": "pypi",
      "registryBaseUrl": "https://pypi.org",
      "identifier": "lore-sdk",
      "version": "1.3.0",
      "runtimeHint": "uvx",
      "runtimeArguments": [
        { "type": "named", "name": "--from", "value": "lore-sdk[mcp]" }
      ],
      "packageArguments": [
        { "type": "positional", "value": "lore-memory" }
      ],
      "transport": {
        "type": "stdio"
      }
    }
  ]
}
