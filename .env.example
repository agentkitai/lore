# Open Brain — Environment Configuration
# Copy to .env and customize for your deployment

# Database (required for server mode)
POSTGRES_PASSWORD=change-me-to-a-secure-random-value
DATABASE_URL=postgresql://openbrain:${POSTGRES_PASSWORD}@db:5432/openbrain

# Server
OPENBRAIN_PORT=8765

# MCP Server (for local mode)
OPENBRAIN_STORE=local
OPENBRAIN_PROJECT=
OPENBRAIN_DB_PATH=~/.openbrain/default.db
OPENBRAIN_MODEL_DIR=~/.openbrain/models

# MCP Server (for remote mode — connects to the API server)
# OPENBRAIN_STORE=remote
# OPENBRAIN_API_URL=http://localhost:8765
# OPENBRAIN_API_KEY=ob_sk_...

# Optional
# OPENBRAIN_REDACT=false
