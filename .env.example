# Lore — Environment Configuration
# Copy to .env and customize for your deployment

# Database (required for server mode)
POSTGRES_PASSWORD=change-me-to-a-secure-random-value
DATABASE_URL=postgresql://lore:${POSTGRES_PASSWORD}@db:5432/lore

# Server
LORE_PORT=8765

# MCP Server (for local mode)
LORE_STORE=local
LORE_PROJECT=
LORE_DB_PATH=~/.lore/default.db
LORE_MODEL_DIR=~/.lore/models

# MCP Server (for remote mode — connects to the API server)
# LORE_STORE=remote
# LORE_API_URL=http://localhost:8765
# LORE_API_KEY=lore_sk_...

# Optional
# LORE_REDACT=false
